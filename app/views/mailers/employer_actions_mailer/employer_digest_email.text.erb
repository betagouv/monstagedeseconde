<% @internship_application_transfered_rows.each_with_index do |row, index| %>
<%= index + 1 %>. <%= row[:student_full_name] %>
- Stage : <%= row[:offer_title] %>
- Voir la candidature : <%= row[:application_url] %>

<% end %>
<% end %>

