Bonjour <%= @user.presenter.formal_name %>,

<% if @pending_application_rows.any? %>
Nouvelles candidatures à traiter :

<% @pending_application_rows.each_with_index do |row, index| %>
<%= index + 1 %>. <%= row[:student_full_name] %>
- Age : <%= row[:age] %>
- Semaine(s) : <%= row[:weeks] %>
- Etablissement : <%= row[:school_name] %> (<%= row[:school_city] %>)
- Contact : <%= row[:student_email] %> / <%= row[:student_phone] %>
- La candidature expire le : <%= row[:expiry_date] %>
<% if row[:motivation].present? %>- Motivation : <%= row[:motivation] %>
<% end %>- Ouvrir la candidature : <%= row[:application_url] %>

<% end %>
<% end %>

<% if @canceled_by_student_rows&.any? %>
Candidatures annulées par l'élève :

<% @canceled_by_student_rows.each_with_index do |row, index| %>
<%= index + 1 %>. <%= row[:student_formal_name] %>
- Stage : <%= row[:offer_title] %>
<% if row[:cancellation_message].present? %>- Motif : <%= row[:cancellation_message] %>
<% end %>
<% end %>
<% end %>

<% if @restored_application_rows&.any? %>
Candidatures restaurées :

<% @restored_application_rows.each_with_index do |row, index| %>
<%= index + 1 %>. <%= row[:student_formal_name] %>
- Stage : <%= row[:offer_title] %>
<% if row[:restoration_message].present? %>- Motif : <%= row[:restoration_message] %>
<% end %>- Voir la candidature : <%= row[:application_url] %>

<% end %>
<% end %>

<% if @chose_another_internship_rows&.any? %>
Élèves ayant choisi un autre stage :

<% @chose_another_internship_rows.each_with_index do |row, index| %>
<%= index + 1 %>. <%= row[:student_full_name] %> a confirmé sa présence pour un autre stage (<%= row[:offer_title] %>).
- Gérer mes candidatures : <%= row[:manage_url] %>

<% end %>
<% end %>

<% if @internship_application_transfered_rows&.any? %>
